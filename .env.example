# Base URL of the system under test.
# Defaults to the bundled local mock healthcare app.
# Point this at an authorized staging/test environment ONLY (never production / never a system you don't own).
BASE_URL=http://127.0.0.1:4300

# Optional: enables the AI-assisted features (self-healing locator suggestions,
# NL-to-test authoring). Tests run fully WITHOUT this — AI features degrade gracefully.
ANTHROPIC_API_KEY=

# Model used by the AI helpers when a key is present.
AI_MODEL=claude-opus-4-8

# Deterministic seed for synthetic test-data generation (reproducible runs).
TEST_DATA_SEED=20260619
